---
import Layout from '../layouts/Layout.astro';
import Configurator from '../components/Configurator/Configurator';
import { getRepairIdFromSearch } from '../components/Configurator/konfigurator-url';
import GlassReplacementTop from '../components/GlassReplacementTop/GlassReplacementTop.astro';
import GlassReplacementInfo from '../components/GlassReplacementInfo/GlassReplacementInfo.astro';
import GlassReplacementSteps from '../components/GlassReplacementSteps/GlassReplacementSteps.astro';
import ServiceIntroSection from '../components/ServiceIntroSection/ServiceIntroSection.astro';
import ServiceInfoWithImage from '../components/ServiceInfoWithImage/ServiceInfoWithImage.astro';

const initialRepairId = getRepairIdFromSearch(Astro.url.searchParams);
---

<Layout title="Konfigurator naprawy">
  <Configurator client:only="react" initialRepairId={initialRepairId}>
    <div
      slot="fallback"
      class="relative min-h-[calc(100vh-var(--header-height))] bg-[#fbfcfe]"
      aria-busy="true"
      aria-label="Ładowanie konfiguratora"
    />
  </Configurator>

  <div id="repair-page-sections" class="border-t border-[#e2e8f0]">
    <div data-repair-section="wymiana-szybki" hidden>
      <GlassReplacementTop />
      <GlassReplacementInfo />
      <GlassReplacementSteps />
    </div>

    <div data-repair-section="wyswietlacz" hidden>
      <ServiceIntroSection title="Wymiana wyświetlacza w telefonie – serwis smartfonów Warszawa">
        <p>
          Twój telefon ma <strong>uszkodzony wyświetlacz w Warszawie</strong>? W <strong>SpaceFix Warszawa</strong> specjalizujemy się w profesjonalnej <strong>wymianie wyświetlacza w smartfonach</strong>, w tym dla iPhone, Samsung, Xiaomi i innych marek. Nasza usługa naprawy polega na precyzyjnym <strong>demontażu uszkodzonego ekranu</strong> i montażu nowego, wysokiej jakości modułu wyświetlacza.
        </p>
        <p>
          Dzięki <strong>wymianie wyświetlacza w telefonie</strong> przywracamy Twojemu urządzeniu pełną <strong>funkcjonalność i jakość obrazu</strong>, zapewniając komfort użytkowania jak w nowym smartfonie. Jest to rozwiązanie bardziej <strong>ekonomiczne niż wymiana całego telefonu</strong>, pozwalające na znaczną oszczędność i szybki czas naprawy.
        </p>
        <p>
          Nasi <strong>doświadczeni technicy w Warszawie</strong> wykonują każdą naprawę z najwyższą precyzją, zapewniając pełną <strong>gwarancję jakości naprawy wyświetlacza</strong> i testując działanie zarówno <strong>warstwy dotykowej</strong>, jak i <strong>matrycy ekranu</strong> po zakończeniu usługi.
        </p>
      </ServiceIntroSection>

      <ServiceInfoWithImage
        title="Na czym polega wymiana wyświetlacza?"
        imageSrc="/images/fixing-section/screen.jpg"
        imageAlt="Wymiana wyświetlacza w telefonie – serwis ekranu"
      >
        <div slot="firstBlock">
          <p>
            Twój smartfon ma uszkodzony wyświetlacz i utrudnia korzystanie z ulubionych aplikacji oraz codziennych funkcji telefonu? <strong>Wymiana wyświetlacza w telefonie</strong> rozwiąże ten problem! Wymiana wyświetlacza polega na precyzyjnym <strong>demontażu uszkodzonego modułu ekranu</strong> i montażu nowego, wysokiej jakości wyświetlacza zamiennego.
          </p>
          <p>
            Naprawa ta jest bardzo korzystna dla klientów, którzy chcą przywrócić pełną funkcjonalność swojego smartfona bez konieczności wymiany całego urządzenia. Dzięki usłudze wymiany wyświetlacza koszty naprawy mogą być znacznie niższe niż zakup nowego telefonu. Zaletą wymiany wyświetlacza jest również fakt, że telefon po naprawie działa jak nowy, a obraz i dotyk są w pełni sprawne.
          </p>
        </div>
        <p slot="thirdBlock">
          <strong>Wymiana wyświetlacza w telefonie</strong><br />Pomimo dodatkowej ochrony poprzez szkła hartowane lub folie ochronne, wyświetlacz może ulec uszkodzeniu, co utrudnia lub uniemożliwia swobodne korzystanie ze smartfona. Wymiana wyświetlacza przywraca jego pełną funkcjonalność i komfort użytkowania. Wybierając serwis <strong>SpaceFix</strong> masz pewność, że ekran przejdzie wszelkie możliwe testy związane z poprawnym działaniem warstwy dotykowej oraz matrycy.
        </p>
        <p slot="fourthBlock">
          Wykonanie usługi wymiany wyświetlacza w telefonie jest możliwe niezależnie od stopnia uszkodzenia poprzedniego ekranu. Jeśli wyświetlacz jest całkowicie niesprawny lub pojawiają się na nim <strong>plamy, linie lub brak reakcji dotyku</strong>, nasza wymiana przywróci pełną sprawność telefonu.
        </p>
      </ServiceInfoWithImage>

      <GlassReplacementSteps />
    </div>

    <div data-repair-section="bateria" hidden>
      <ServiceIntroSection title="Wymiana baterii w telefonie – serwis smartfonów Warszawa">
        <p>
          Twój telefon <strong>szybko się rozładowuje</strong> lub wyłącza mimo naładowania? W <strong>SpaceFix Warszawa</strong> specjalizujemy się w profesjonalnej <strong>wymianie baterii w smartfonach</strong>, w tym dla iPhone, Samsung, Xiaomi i innych marek. Nasza usługa polega na <strong>demontażu zużytego ogniwa</strong> i montażu nowej, wysokiej jakości baterii.
        </p>
        <p>
          Dzięki <strong>wymianie baterii w telefonie</strong> przywracamy urządzeniu <strong>pełną wydajność i dłuższy czas pracy</strong>, zapewniając komfort użytkowania jak w nowym smartfonie. To rozwiązanie znacznie bardziej <strong>ekonomiczne niż wymiana całego telefonu</strong>.
        </p>
        <p>
          Nasi <strong>doświadczeni technicy w Warszawie</strong> wykonują każdą naprawę z najwyższą precyzją, zapewniając pełną <strong>gwarancję jakości</strong> oraz sprawdzając poprawność <strong>ładowania i kondycji nowej baterii</strong> po zakończeniu usługi.
        </p>
      </ServiceIntroSection>

      <ServiceInfoWithImage
        title="Na czym polega wymiana baterii?"
        imageSrc="/images/fixing-section/battery.jpg"
        imageAlt="Wymiana baterii w telefonie – serwis smartfonów"
      >
        <div slot="firstBlock">
          <p>
            Twój smartfon <strong>rozładowuje się znacznie szybciej</strong> niż kiedyś, a komunikaty o kondycji baterii sugerują jej zużycie? <strong>Wymiana baterii w telefonie</strong> rozwiąże ten problem! Wymiana polega na <strong>demontażu zużytego ogniwa</strong> i montażu nowej, wysokiej jakości baterii zamiennej.
          </p>
          <p>
            Naprawa ta jest bardzo korzystna dla klientów, którzy chcą przywrócić pełną sprawność swojego telefonu bez konieczności zakupu nowego urządzenia. Dzięki usłudze wymiany baterii telefon ponownie <strong>utrzymuje naładowanie przez cały dzień</strong>, a koszty naprawy są znacznie niższe niż zakup nowego smartfona.
          </p>
        </div>
        <p slot="thirdBlock">
          Bateria to <strong>element eksploatacyjny</strong>, którego pojemność spada z każdym cyklem ładowania. Wymiana baterii w telefonie przywraca jego <strong>pełną wydajność i czas pracy</strong>. Wybierając serwis <strong>SpaceFix</strong> masz pewność, że nowe ogniwo przejdzie wszelkie możliwe testy związane z poprawnym <strong>ładowaniem i bezpieczeństwem</strong> urządzenia.
        </p>
        <p slot="fourthBlock">
          Wykonanie usługi wymiany baterii jest możliwe niezależnie od stopnia jej zużycia. Jeśli telefon <strong>nagle się wyłącza, puchnie lub szybko traci procenty</strong>, nasza wymiana przywróci pełną sprawność i bezpieczeństwo użytkowania.
        </p>
      </ServiceInfoWithImage>

      <GlassReplacementSteps />
    </div>

    <div data-repair-section="naprawa-zalania" hidden>
      <ServiceIntroSection title="Naprawa telefonu po zalaniu – serwis smartfonów Warszawa">
        <p>
          Twój telefon uległ <strong>zalaniu w Warszawie</strong> lub przestał działać po kontakcie z cieczą? W <strong>SpaceFix Warszawa</strong> specjalizujemy się w profesjonalnej <strong>naprawie smartfonów po zalaniu</strong>, zarówno dla iPhone, Samsung, Xiaomi, jak i innych marek. Nasza usługa rozpoczyna się od <strong>dokładnej diagnostyki telefonu po zalaniu</strong>, dzięki której ustalamy, które podzespoły wymagają naprawy - może to być <strong>płyta główna, dysk/twardy lub wyświetlacz smartfona</strong>.
        </p>
        <p>
          Dzięki naszej <strong>naprawie telefonu po kontakcie z cieczą</strong> w Warszawie możemy spróbować przywrócić Twój smartfon do życia, nawet jeśli uległy uszkodzeniu kluczowe komponenty. Jeśli naprawa nie jest możliwa, oferujemy <strong>odzyskiwanie danych z zalanego telefonu</strong>, abyś mógł zachować wszystkie ważne pliki.
        </p>
        <p>
          Nasi <strong>doświadczeni technicy w Warszawie</strong> wykorzystują specjalistyczny sprzęt i nowoczesne metody serwisowe, zapewniając pełną <strong>gwarancję jakości naprawy telefonu po zalaniu</strong> oraz sprawdzając pełną funkcjonalność urządzenia po zakończeniu usługi.
        </p>
      </ServiceIntroSection>

      <ServiceInfoWithImage
        title="Na czym polega naprawa telefonu po zalaniu?"
        imageSrc="/images/fixing-section/water.jpg"
        imageAlt="Naprawa telefonu po zalaniu – diagnostyka i serwis"
      >
        <div slot="firstBlock">
          <p>
            Twój smartfon uległ <strong>zalaniu</strong>, co utrudnia korzystanie z aplikacji i codziennych funkcji telefonu? <strong>Naprawa telefonu po zalaniu</strong> rozwiąże ten problem! Naprawa telefonu po kontakcie z cieczą polega na <strong>dokładnej diagnostyce</strong>, ustaleniu, które podzespoły zostały uszkodzone - może to być <strong>płyta główna, dysk/twardy lub wyświetlacz</strong> - oraz profesjonalnej <strong>naprawie telefonu po zalaniu</strong> tych elementów.
          </p>
          <p>
            Usługa ta jest bardzo korzystna dla klientów, którzy chcą przywrócić funkcjonalność swojego telefonu bez konieczności zakupu nowego urządzenia. Dzięki naprawie telefonu po zalaniu możemy przywrócić jego pełne działanie, a jeśli naprawa nie jest możliwa, oferujemy <strong>odzyskiwanie danych</strong>, aby zachować ważne pliki.
          </p>
        </div>
        <p slot="thirdBlock">
          Pomimo ostrożności, zalanie smartfona może zdarzyć się każdemu. Naprawa telefonu po zalaniu przywraca jego pełną funkcjonalność, przywracając działanie zarówno wyświetlacza, jak i wszystkich kluczowych podzespołów. Wybierając serwis <strong>SpaceFix</strong> masz pewność, że Twój telefon przejdzie wszelkie możliwe testy sprawnościowe i diagnostyczne, a nasi <strong>doświadczeni technicy</strong> zajmą się zarówno płytą główną, dyskiem, jak i wyświetlaczem.
        </p>
        <p slot="fourthBlock">
          Wykonanie usługi naprawy telefonu po zalaniu jest możliwe nawet w przypadku poważnych uszkodzeń. Jeśli urządzenie jest sprawne po naprawie, przywracamy pełną funkcjonalność telefonu. Jeśli natomiast podzespoły są nie do uratowania, oferujemy <strong>odzyskiwanie danych</strong>, aby żadne informacje nie zostały utracone.
        </p>
      </ServiceInfoWithImage>

      <GlassReplacementSteps />
    </div>

    <div data-repair-section="wymiana-tylnej-szyby" hidden>
      <ServiceIntroSection title="Wymiana tylnej szyby w telefonie – serwis smartfonów Warszawa">
        <p>
          Twój telefon ma <strong>rozbity tylny panel</strong> lub pękniętą szybę z tyłu obudowy? W <strong>SpaceFix Warszawa</strong> specjalizujemy się w profesjonalnej <strong>wymianie tylnej szyby w smartfonach</strong>, w tym dla iPhone, Samsung, Xiaomi i innych marek. Nasza usługa polega na precyzyjnym <strong>usunięciu uszkodzonego szkła</strong> i montażu nowego, wysokiej jakości panelu.
        </p>
        <p>
          Dzięki <strong>wymianie tylnej szyby w telefonie</strong> przywracamy urządzeniu <strong>estetyczny wygląd i pełną szczelność obudowy</strong>, zachowując komfort użytkowania jak w nowym smartfonie. To rozwiązanie bardziej <strong>ekonomiczne niż wymiana całej obudowy</strong>.
        </p>
        <p>
          Nasi <strong>doświadczeni technicy w Warszawie</strong> wykonują każdą naprawę z najwyższą precyzją, zapewniając pełną <strong>gwarancję jakości</strong> oraz sprawdzając poprawne osadzenie nowego panelu po zakończeniu usługi.
        </p>
      </ServiceIntroSection>

      <ServiceInfoWithImage
        title="Na czym polega wymiana tylnej szyby?"
        imageSrc="/images/fixing-section/back.jpg"
        imageAlt="Wymiana tylnej szyby w telefonie – serwis smartfonów"
      >
        <div slot="firstBlock">
          <p>
            Twój smartfon ma <strong>rozbitą tylną szybę</strong>, która psuje wygląd telefonu i grozi dalszymi uszkodzeniami? <strong>Wymiana tylnej szyby w telefonie</strong> rozwiąże ten problem! Naprawa polega na precyzyjnym <strong>usunięciu uszkodzonego szkła z tyłu obudowy</strong> i montażu nowego, wysokiej jakości panelu zamiennego.
          </p>
          <p>
            Naprawa ta jest bardzo korzystna dla klientów, którzy chcą przywrócić estetyczny wygląd swojego telefonu bez konieczności wymiany całej obudowy. Dzięki usłudze wymiany tylnej szyby koszty naprawy są znacznie niższe, a telefon po naprawie <strong>wygląda jak nowy</strong>.
          </p>
        </div>
        <p slot="thirdBlock">
          Pomimo dodatkowej ochrony w postaci etui, tylna szyba telefonu może <strong>pęknąć po upadku</strong>, narażając wnętrze urządzenia na kurz i wilgoć. Wymiana tylnej szyby przywraca pełną <strong>szczelność i estetykę obudowy</strong>. Wybierając serwis <strong>SpaceFix</strong> masz pewność, że nowy panel zostanie osadzony precyzyjnie i trwale.
        </p>
        <p slot="fourthBlock">
          Wykonanie usługi wymiany tylnej szyby jest możliwe niezależnie od stopnia uszkodzenia panelu. Jeśli szyba jest <strong>popękana, odklejona lub całkowicie rozbita</strong>, nasza wymiana przywróci pełną sprawność i estetykę telefonu.
        </p>
      </ServiceInfoWithImage>

      <GlassReplacementSteps />
    </div>
  </div>
</Layout>

<script>
  type ConfiguratorStateDetail = { step?: number; repairId?: string | null };

  function applyConfiguratorState(step?: number, repairId?: string | null) {
    const container = document.getElementById('repair-page-sections');
    if (!container) return;

    const sections = container.querySelectorAll<HTMLElement>('[data-repair-section]');
    sections.forEach((section) => {
      section.hidden = true;
    });

    if (step === 5 && repairId) {
      const match = container.querySelector<HTMLElement>(
        `[data-repair-section="${repairId}"]`,
      );
      if (match) match.hidden = false;
    }
  }

  window.addEventListener('configurator:state', (event) => {
    const detail = (event as CustomEvent<ConfiguratorStateDetail>).detail ?? {};
    applyConfiguratorState(detail.step, detail.repairId);
  });
</script>
