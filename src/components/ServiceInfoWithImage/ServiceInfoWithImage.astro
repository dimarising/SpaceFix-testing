---
interface Props {
  title: string;
  imageSrc: string;
  imageAlt: string;
}

const { title, imageSrc, imageAlt } = Astro.props;

const textClass = 'text-[15px] leading-relaxed text-[#64748b] sm:text-base';
const plainTextClass = 'prose-service space-y-4';
---

<section class="section-padding bg-white">
  <div class="section-container">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-x-10 lg:gap-y-8">
      <div class="flex flex-col gap-5 lg:col-start-1 lg:row-start-1">
        <h2 class="text-2xl font-bold text-[#010101] sm:text-3xl">{title}</h2>
        <div class:list={['prose-service space-y-4', textClass]}>
          <slot name="firstBlock" />
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl shadow-contact lg:col-start-2 lg:row-start-1 lg:self-start">
        <img
          src={imageSrc}
          alt={imageAlt}
          class="aspect-[4/3] h-full w-full object-cover lg:aspect-auto lg:min-h-[320px]"
          loading="lazy"
        />
      </div>

      <div class:list={[plainTextClass, textClass, 'lg:col-start-1 lg:row-start-2']}>
        <slot name="thirdBlock" />
      </div>

      <div class:list={[plainTextClass, textClass, 'lg:col-start-2 lg:row-start-2']}>
        <slot name="fourthBlock" />
      </div>
    </div>
  </div>
</section>
