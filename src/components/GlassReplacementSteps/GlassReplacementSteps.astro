---
const steps = [
  {
    number: '01',
    title: 'Przyjęcie telefonu',
    description:
      'Sporządzamy kartę przyjęcia z opisem usterki, wyceną i szacowanym czasem odbioru. Otrzymujesz egzemplarz karty do okazania przy odbiorze.',
  },
  {
    number: '02',
    title: 'Naprawa',
    description:
      'Technicy wykonują usługę z najwyższą starannością — precyzyjna praca, testy wyświetlacza i warstwy dotykowej po zakończeniu.',
  },
  {
    number: '03',
    title: 'Odbior',
    description:
      'Kontaktujemy się, gdy telefon jest gotowy. Przy odbiorze okazujesz kartę i dokonujesz płatności. Każda naprawa objęta jest 6-miesięczną gwarancją.',
  },
];
---

<section class="section-padding bg-[#fbfcfe]">
  <div class="section-container">
    <h2 class="mb-10 text-center text-2xl font-bold text-[#010101] sm:mb-12 sm:text-3xl">
      Jak wygląda naprawa?
    </h2>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        steps.map((step) => (
          <article class="relative flex flex-col items-center rounded-2xl bg-white px-6 pb-8 pt-10 text-center shadow-contact sm:px-8 sm:pb-10">
            <div
              class="absolute left-1/2 top-0 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-[#1c1d11] text-xs font-bold text-white"
              aria-hidden="true"
            >
              {step.number}
            </div>
            <h3 class="text-lg font-bold text-[#010101] sm:text-xl">{step.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-[#64748b] sm:text-base">
              {step.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
