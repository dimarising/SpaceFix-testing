---
import WhyUsFeatureItem from './WhyUsFeatureItem.astro';
import WhyUsStatItem from './WhyUsStatItem.astro';
import { whyUsFeatures, whyUsStats } from './why-us-data';
---

<section
  id="dlaczego-my"
  class="relative flex min-h-[862px] items-center overflow-hidden bg-[#fbfcfe] section-padding scroll-mt-[var(--header-height)]"
>
  <div
    class="pointer-events-none absolute inset-y-0 left-1/2 w-full max-w-[1440px] -translate-x-1/2 bg-cover bg-[center_0%] bg-no-repeat"
    style="background-image: url('/images/assets/why-spacefix.png');"
    aria-hidden="true"
  />
  <div class="pointer-events-none absolute inset-0 bg-[#fbfcfe]/75" aria-hidden="true" />

  <div class="section-container relative">
    <div class="mx-auto mb-10 max-w-3xl text-center md:mb-12">
      <h2 class="section-title mb-4">Dlaczego SpaceFix?</h2>
      <p class="section-subtitle mx-auto">
        Zaufaj specjalistom z wieloletnim doświadczeniem
      </p>
    </div>

    <div class="mb-10 grid grid-cols-1 gap-10 sm:grid-cols-2 sm:gap-8 lg:mb-12 lg:grid-cols-4 lg:gap-6">
      {whyUsFeatures.map((feature) => <WhyUsFeatureItem {...feature} />)}
    </div>

    <div class="rounded-2xl bg-white py-6 shadow-contact md:h-[178px] md:py-0 md:rounded-3xl">
      <div class="grid grid-cols-2 grid-rows-2 place-items-center gap-y-4 md:h-full md:grid-cols-4 md:grid-rows-1 md:gap-y-0">
        {whyUsStats.map((stat) => <WhyUsStatItem {...stat} />)}
      </div>
    </div>
  </div>
</section>
