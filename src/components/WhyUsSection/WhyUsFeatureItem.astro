---
import type { WhyUsFeature } from './why-us-data';

interface Props extends WhyUsFeature {}

const { title, description, iconSrc } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <div
    class="mb-4 flex h-20 w-20 shrink-0 items-center justify-center rounded-xl bg-[#1c1d11] shadow-sm"
    aria-hidden="true"
  >
    <img src={iconSrc} alt="" width="40" height="40" class="h-10 w-10" />
  </div>
  <h3 class="text-[20px] font-bold text-surface-dark">{title}</h3>
  <p
    class="mt-2 max-w-[19rem] text-[15px] leading-relaxed text-[#2A2C11] [&_strong]:font-semibold [&_strong]:text-surface-dark"
    set:html={description}
  />
</div>
