---
import { FiChevronRight } from 'react-icons/fi';
import { GiLaserBlast } from 'react-icons/gi';
import { IoWaterOutline } from 'react-icons/io5';
import {
  MdBatteryChargingFull,
  MdMonitor,
  MdOutlinePhonelinkSetup,
  MdSmartphone,
} from 'react-icons/md';
import type { PopularRepair, PopularRepairIcon } from './popular-repairs-data';

interface Props extends PopularRepair {}

const { title, description, href, linkLabel, icon } = Astro.props;

const icons: Record<PopularRepairIcon, typeof MdSmartphone> = {
  smartphone: MdSmartphone,
  monitor: MdMonitor,
  battery: MdBatteryChargingFull,
  water: IoWaterOutline,
  backGlass: MdOutlinePhonelinkSetup,
  laser: GiLaserBlast,
};

const Icon = icons[icon];
---

<a
  href={href}
  class="group flex h-full flex-col rounded-2xl bg-white p-6 shadow-contact transition hover:shadow-card-hover sm:p-8"
>
  <div
    class="mb-5 flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-[#eeeeec] text-[#1c1d11] sm:mb-6 sm:h-16 sm:w-16"
    aria-hidden="true"
  >
    <Icon className="h-7 w-7 sm:h-8 sm:w-8" />
  </div>

  <h3 class="text-lg font-bold text-surface-dark sm:text-xl">{title}</h3>
  <p class="mt-2 flex-1 text-[15px] leading-relaxed text-[#2A2C11] sm:text-base">{description}</p>

  <span
    class="mt-5 inline-flex items-center gap-1 text-[16px] font-semibold text-surface-dark transition group-hover:gap-2 sm:mt-6"
  >
    {linkLabel}
    <FiChevronRight className="h-5 w-5 shrink-0 stroke-[2.5]" aria-hidden="true" />
  </span>
</a>
