---
import { FiPhone } from 'react-icons/fi';
import { contact } from '../../config/site';
import PopularRepairCard from './PopularRepairCard.astro';
import { popularRepairs } from './popular-repairs-data';

const phoneButtonClass =
  'inline-flex w-full max-w-md items-center justify-center gap-2 rounded-[14px] bg-[#1c1d11] px-9 py-4 text-sm font-bold text-white transition hover:bg-[#2a2b1a] focus:outline-none focus:ring-2 focus:ring-[#1c1d11] focus:ring-offset-2 sm:text-base lg:w-auto lg:max-w-none';
---

<section
  id="naprawy"
  class="flex min-h-[1044px] flex-col justify-center bg-[#fbfcfe] py-16 scroll-mt-[var(--header-height)] md:py-20 lg:py-24"
>
  <div class="section-container flex flex-col">
    <div class="mx-auto mb-10 max-w-3xl text-center md:mb-12 lg:mb-14">
      <h2 class="section-title mb-4">Najpopularniejsze naprawy</h2>
      <p class="section-subtitle mx-auto">
        Szybka i profesjonalna naprawa Twojego telefonu. Sprawdź nasze usługi.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 lg:gap-8">
      {popularRepairs.map((repair) => <PopularRepairCard {...repair} />)}
    </div>

    <div class="mt-10 flex flex-col items-center gap-5 text-center sm:mt-12 sm:gap-6 lg:mt-14">
      <p class="text-[24px] text-[#64748b]">Nieznalazłeś swojego problemu?</p>
      <a href={contact.phoneHref} class={phoneButtonClass}>
        <FiPhone className="h-5 w-5 shrink-0" aria-hidden="true" />
        Zadzwoń {contact.phoneDisplay}
      </a>
    </div>
  </div>
</section>
