---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="section-padding bg-[#fbfcfe]">
  <div class="section-container">
    <h2 class="text-2xl font-bold text-[#010101] sm:text-3xl">{title}</h2>
    <div
      class="prose-service mt-5 max-w-none space-y-4 text-[15px] leading-relaxed text-[#64748b] sm:text-base"
    >
      <slot />
    </div>
  </div>
</section>
