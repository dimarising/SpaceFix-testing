---
import { LuClock, LuMapPin } from 'react-icons/lu';
import { contact, openingHours } from '../../config/site';

const galleryImages = [
  {
    src: '/images/assets/inside-service.png',
    alt: 'Wnętrze serwisu SpaceFix w Ursusie',
  },
  {
    src: '/images/assets/service.png',
    alt: 'Front serwisu SpaceFix',
  },
  {
    src: '/images/assets/magazine.png',
    alt: 'Zespół SpaceFix podczas pracy',
  },
];

const darkButtonClass =
  'inline-flex w-full shrink-0 items-center justify-center gap-2 rounded-[14px] bg-[#1c1d11] px-5 py-3 text-sm font-bold text-white transition hover:bg-[#2a2b1a] focus:outline-none focus:ring-2 focus:ring-[#1c1d11] focus:ring-offset-2 sm:text-base';

const contactPanelClass = 'rounded-xl bg-white shadow-contact';
---

<section id="kontakt" class="section-padding bg-[#fbfcfe] scroll-mt-[var(--header-height)]">
  <div class="section-container">
    <div class="mx-auto mb-8 max-w-3xl text-center md:mb-10">
      <h2 class="section-title mb-4">Odwiedź nas w Ursusie</h2>
      <p class="section-subtitle mx-auto">Jesteśmy blisko Ciebie. Wpadnij do naszego serwisu!</p>
    </div>

    <div class="mb-8 md:mb-10">
      <div class="md:hidden">
        <img
          src={galleryImages[0].src}
          alt={galleryImages[0].alt}
          class="aspect-[16/10] w-full rounded-2xl object-cover object-center shadow-contact"
          loading="lazy"
        />
      </div>

      <div
        class="hidden gap-4 md:grid md:h-[388px] md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)_minmax(0,1fr)] md:grid-rows-1 md:gap-5 md:items-stretch"
      >
        {
          galleryImages.map((image) => (
            <div class="h-full min-h-0 overflow-hidden rounded-2xl shadow-contact">
              <img
                src={image.src}
                alt={image.alt}
                class="h-full w-full object-cover object-center"
                loading="lazy"
              />
            </div>
          ))
        }
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:items-stretch lg:gap-8">
      <div class="flex flex-col gap-4 lg:col-span-5 lg:gap-5">
        <div class={`${contactPanelClass} shrink-0 p-5 sm:p-6`}>
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#eeeeec] text-slate-600">
              <LuMapPin className="h-5 w-5" aria-hidden="true" />
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-lg font-bold text-surface-dark sm:text-xl">Nasz adres</h3>
              <div class="mt-2 space-y-0.5 text-[16px] text-[#2A2C11]">
                <p>SpaceFix - Serwis GSM</p>
                <p>{contact.addressLine1}</p>
                <p>{contact.addressLine2}</p>
              </div>
            </div>
          </div>

          <a
            href={contact.mapsDirectionsHref}
            target="_blank"
            rel="noopener noreferrer"
            class={`${darkButtonClass} mt-5`}
          >
            <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
            </svg>
            Nawiguj do serwisu
          </a>
        </div>

        <div class={`${contactPanelClass} shrink-0 p-5 sm:p-6`}>
          <div class="flex items-start gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#eeeeec] text-slate-600">
              <LuClock className="h-5 w-5" aria-hidden="true" />
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-lg font-bold text-surface-dark sm:text-xl">Godziny otwarcia</h3>
              <dl class="mt-3 space-y-2">
                {
                  openingHours.map((entry) => (
                    <div class="flex items-center justify-between gap-4 text-sm">
                      <dt class="font-medium text-surface-dark">{entry.days}</dt>
                      <dd class="shrink-0 font-medium text-[#010101]">{entry.hours}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </div>

        <a href={contact.phoneHref} class={darkButtonClass}>
          <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          Zadzwoń teraz
        </a>

        <div class="shrink-0 rounded-xl bg-[#eaebeb] p-5 shadow-contact sm:p-6">
          <h3 class="text-base font-bold text-surface-dark sm:text-lg">Potrzebujesz pomocy?</h3>
          <p class="mt-2 text-[16px] text-[#2A2C11]">
            Nasz zespół jest gotowy odpowiedzieć na wszystkie pytania dotyczące naprawy Twojego telefonu.
          </p>
          <p class="mt-3 text-sm">
            Tel: <a href={contact.phoneHref} class="font-bold text-surface-dark hover:text-brand-600">{contact.phoneDisplay}</a>
          </p>
        </div>
      </div>

      <div class="lg:col-span-7 lg:h-full">
        <div class={`${contactPanelClass} h-[320px] overflow-hidden sm:h-[400px] lg:h-full`}>
          <iframe
            src={contact.mapsEmbedSrc}
            width="100%"
            height="100%"
            class="block h-full w-full border-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Mapa SpaceFix — Serwis GSM w Ursusie"></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
