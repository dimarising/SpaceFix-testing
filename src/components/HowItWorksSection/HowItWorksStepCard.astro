---
import { FiCheckCircle, FiPhone, FiSearch } from 'react-icons/fi';
import type { HowItWorksStep, HowItWorksStepIcon } from './how-it-works-data';

interface Props extends HowItWorksStep {
  class?: string;
}

const { number, title, description, icon, class: className = '' } = Astro.props;

const icons: Record<HowItWorksStepIcon, typeof FiPhone> = {
  phone: FiPhone,
  search: FiSearch,
  check: FiCheckCircle,
};

const Icon = icons[icon];
---

<article
  class:list={[
    'relative flex w-full flex-col items-center rounded-xl bg-white px-6 pb-8 pt-10 text-center shadow-contact sm:px-8 sm:pb-10 sm:pt-12',
    className,
  ]}
>
  <div
    class="absolute left-1/2 top-0 flex h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-[#1c1d11] text-[14px] font-bold text-white"
    aria-hidden="true"
  >
    {number}
  </div>

  <div
    class="mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-[#eeeeec] text-[#1c1d11] sm:mb-6 sm:h-[5rem] sm:w-[5rem]"
    aria-hidden="true"
  >
    <Icon className="h-10 w-10 sm:h-8 sm:w-8" />
  </div>

  <h3 class="text-lg font-bold text-surface-dark sm:text-xl">{title}</h3>
  <p class="mt-2 text-[15px] leading-relaxed text-[#2A2C11] sm:text-base">
    {description}
  </p>
</article>
