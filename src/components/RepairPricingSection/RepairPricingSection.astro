---
import { contact } from '../../config/site';
import { pricingFeatures, pricingRows } from './pricing-data';

const tableColumns = [
  { key: 'model', label: 'Model', align: 'text-left' },
  { key: 'screen', label: 'Wymiana szybki', align: 'text-center' },
  { key: 'battery', label: 'Bateria', align: 'text-center' },
  { key: 'waterDamage', label: 'Naprawa zalania', align: 'text-center', hideOnMobile: true },
] as const;
---

<section id="cennik" class="section-padding bg-[#fbfcfe] scroll-mt-[var(--header-height)]">
  <div class="section-container">
    <div class="mx-auto mb-10 max-w-3xl text-center md:mb-12">
      <h2 class="section-title mb-4">Cennik napraw</h2>
      <p class="section-subtitle mx-auto">
        Przejrzyste i konkurencyjne ceny. Dokładna wycena po darmowej diagnozie.
      </p>
    </div>

    <div class="card overflow-hidden shadow-contact">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[20rem] border-collapse text-sm md:text-base">
          <thead>
            <tr class="bg-surface-dark text-white">
              {
                tableColumns.map((column) => (
                  <th
                    scope="col"
                    class:list={[
                      'px-4 py-4 font-semibold first:pl-6 last:pr-6 md:px-6 md:py-5',
                      column.align,
                      column.hideOnMobile && 'hidden md:table-cell',
                    ]}
                  >
                    {column.label}
                  </th>
                ))
              }
            </tr>
          </thead>
          <tbody>
            {
              pricingRows.map((row, index) => (
                <tr
                  class:list={[
                    'border-b border-slate-200/80 last:border-b-0',
                    index % 2 === 0 ? 'bg-white' : 'bg-slate-50/50',
                  ]}
                >
                  <td class="px-4 py-4 pl-6 font-semibold text-surface-dark md:px-6 md:py-5">
                    {row.model}
                  </td>
                  <td class="px-4 py-4 text-center text-surface-dark md:px-6 md:py-5">{row.screen}</td>
                  <td class="px-4 py-4 text-center text-surface-dark md:px-6 md:py-5">{row.battery}</td>
                  <td class="hidden px-4 py-4 text-center text-surface-dark md:table-cell md:px-6 md:py-5">
                    {row.waterDamage ?? ''}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <p class="border-t border-slate-200/80 px-4 py-4 text-center text-xs text-[#010101] md:text-sm">
        * Ceny orientacyjne • Dokładna wycena po darmowej diagnozie
      </p>
    </div>

    <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center md:mt-10">
      <a
        href="/konfigurator/"
        class="inline-flex w-full items-center justify-center gap-2 rounded-[14px] bg-[#1c1d11] px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-[#2a2b1a] focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 active:scale-[0.98] sm:w-auto"
      >
        <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
          />
        </svg>
        Wyceń Naprawę
      </a>
      <a
        href={contact.phoneHref}
        class="inline-flex w-full items-center justify-center gap-2 rounded-[14px] border border-[#EBEBEB] bg-[#FFFFFF] px-6 py-3.5 text-base font-semibold text-surface-dark shadow-sm transition hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 active:scale-[0.98] sm:w-auto"
      >
        <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          />
        </svg>
        Zadzwoń {contact.phoneDisplay}
      </a>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-4 md:mt-10 md:grid-cols-3 md:gap-6">
      {
        pricingFeatures.map((feature) => (
          <div class="card flex items-start gap-4 p-5 shadow-contact md:p-6">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-surface-dark"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <div>
              <h3 class="font-bold text-surface-dark">{feature.title}</h3>
              <p class="mt-1 text-[14px] text-[#2A2C11]">{feature.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
